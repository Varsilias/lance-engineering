        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "if (response.data && response.data.access_token) {",
              "    pm.environment.set(\"nest_user\", response.data.access_token);",
              "}",
              "",
              "if (response.data && response.data.refresh_token) {",
